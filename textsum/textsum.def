Bootstrap: docker
From: nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04

%files
    requirements.txt /requirements.txt
    model /model

%post
    export DEBIAN_FRONTEND=noninteractive
    # Apptainer bind-mounts the host /tmp into %post; on a login node with a
    # full root filesystem that makes pip's wheel-unpack hit ENOSPC. Stage
    # pip temp inside the sandbox rootfs (on Lustre during build) instead.
    export TMPDIR=/buildtmp
    mkdir -p /buildtmp
    # nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04 ships python3.11=3.11.0~rc1
    # (a pre-release with different internal struct layouts than 3.11.x stable).
    # Triton's pybind11 C++ extension is built against 3.11-stable ABI; on rc1
    # the IRBuilder type's instance __dict__ is left uninitialised, so the first
    # `self.builder.options = options` SEGFAULTs in _PyDictKeys_StringLookup
    # (gdb py-bt in v15-F nailed this). LANTA's shared venv runs vllm 0.19.1 +
    # Triton 3.6.0 against Python 3.11.7 stable and works fine.
    # Fix: install python3.11 from the deadsnakes PPA, which currently ships
    # 3.11.13+. add-apt-repository requires software-properties-common.
    apt-get update && apt-get install -y software-properties-common gnupg ca-certificates && rm -rf /var/lib/apt/lists/*
    add-apt-repository -y ppa:deadsnakes/ppa
    apt-get update && apt-get install -y python3.11 python3.11-dev python3.11-distutils python3-pip && rm -rf /var/lib/apt/lists/*
    ln -sf /usr/bin/python3.11 /usr/bin/python3
    # v16.1 needs NO nvcc: run.py sets VLLM_USE_DEEP_GEMM=0 and keeps
    # kv_cache_dtype="auto", forcing the precompiled Marlin/Triton FP8 path on
    # both A100 and H100 (no runtime JIT). This is the lean single-model image
    # — the v21 hybrid's cuda-minimal-build/nvcc bake is dropped here.
    # torch 2.10.0 wheels live on the cu128 index (matches CUDA 12.8.1 base).
    pip3 install --no-cache-dir --timeout 300 --retries 5 torch==2.10.0 --index-url https://download.pytorch.org/whl/cu128
    pip3 install --no-cache-dir --timeout 300 --retries 5 -r /requirements.txt
    # v16.1: single-model exp51 port (leak-free 0.7110, +0.0023 over v16's
    # 0.7087). One model — Qwen3-30B-A3B-Instruct-2507-FP8 (MoE, ~30 GB
    # FP8). Proven-buildable, H100-safe single-model fallback to the v21
    # two-stage hybrid (~50 GB) on master. Bundle the one weight (~30 GB SIF).
    python3 -c "from huggingface_hub import snapshot_download; \
snapshot_download('Qwen/Qwen3-30B-A3B-Instruct-2507-FP8')"
    mkdir -p /scratch && chmod 1777 /scratch
    rm -rf /buildtmp

%environment
    export HF_HOME=/root/.cache/huggingface
    export HF_HUB_OFFLINE=1
    export TRANSFORMERS_OFFLINE=1
    export TEXTSUM_SCRATCH_DIR=/scratch
    # vllm 0.19.1's V1 engine spawns an EngineCore subprocess that segfaults
    # inside Apptainer right after model load (verified on v11 bump attempt,
    # job 5787048 — FLASHINFER/TRITON_ATTN/FLEX_ATTENTION all segfault, so
    # not an attention-backend issue; root cause is V1 process model). V0
    # uses in-process workers — no subprocess, no segfault.
    export VLLM_USE_V1=0

%runscript
    cd /model
    exec python3 run.py
